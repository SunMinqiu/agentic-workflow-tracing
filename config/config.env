# Minimal config for the Pi + BCC/eBPF tracing workflow.
# Update these values for the target machine before running.

# Repository root containing one subdirectory per case/repo to trace.
CASES_DIR="/mnt/lus_fs/cases"

# Optional path hint used by downstream parsing/filtering.
WORKSPACE_PATH="/mnt/lus_fs"

# Output directory for trace artifacts.
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/$(date +%Y%m%d_%H%M%S)}"

# Optional comma-separated subset of repos inside CASES_DIR.
RUN_REPOS="gfdl-am4"

# Pi model selection.
export PI_MODEL="openai/gpt-5.2"

# Optional provider override.
# export PI_PROVIDER="openai"

# Optional interpreter overrides for the orchestration script.
# export AGENT_PYTHON="/path/to/python3"
# export POST_PYTHON="python3"

# Optional extra args passed to analyze_codebase_pi.py.
# `--no-skill` avoids the original hardcoded skill-path requirement.
PI_ANALYZE_ARGS="--no-skill"
