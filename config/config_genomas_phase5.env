# Phase 5 config: single cell, mw=2 fixed, FULL pipeline (no --quick-test).
# Goal: get a clean LLM-time + code-exec-time + gap breakdown for ONE run,
# proving the code-exec hook works and exposing whatever compute-bound
# behavior shows up even on the small 1-cohort dataset.
#
# Source this instead of config_genomas.env via:
#   CONFIG_FILE=$SCRIPT_DIR/config_genomas_phase5.env bash trace_script_bcc_genomas.sh

WORK_DIR="${WORK_DIR:-/tmp/genomas_work_p5}"
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR_GENOMAS:-/mnt/lustrefs/genomas_data}}"
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/phase5_$(date +%Y%m%d_%H%M%S)}"

GENOMAS_REPO="${GENOMAS_REPO:-$HOME/GenoMAS}"

BCC_INCLUDE_NET=1
RUN_WORKLOADS=""
INTER_RUN_SLEEP_SEC=0

TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$GENOMAS_REPO/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

export OPENAI_API_KEY_1="${OPENAI_API_KEY_1:-${OPENAI_API_KEY:-}}"
export OPENAI_ORGANIZATION_1="${OPENAI_ORGANIZATION_1:-${OPENAI_ORGANIZATION:-}}"
export ANTHROPIC_API_KEY_1="${ANTHROPIC_API_KEY_1:-${ANTHROPIC_API_KEY:-}}"

GENOMAS_MODEL="${GENOMAS_MODEL:-gpt-5-mini-2025-08-07}"
GENOMAS_SMOKE_TRAITS="${GENOMAS_SMOKE_TRAITS:-}"

# Phase 5: ONE cell.
# mw=2 fixed (proven sweet spot; sweep already covered in Phase 4).
# Extra arg "--no-quick-test-sentinel" is a placeholder — the real switch
# is done in trace_script_bcc_genomas.sh logic (drop --quick-test when
# extra_args contains "fullpipeline").
WORKLOADS=(
  "p5_mw2_full|2|1|fullpipeline"
)
