# Config v2: every example from the SRAgent README, one workload per example.
# (https://github.com/ArcInstitute/SRAgent#readme)
#
# Use this when you want broad coverage of SRAgent's documented behaviours,
# not just a single canonical invocation per agent.  For one-per-agent
# coverage use `config_sragent.env` (v1).
#
# Run me with:
#   CONFIG_FILE=~/pi-ebpf-tracing-handoff/config_sragent_all_readme.env \
#     sudo -E bash trace_script_bcc_sragent.sh
#
# Skipped (deliberately):
#   - `srx-info --use-database ...` — requires the optional SQL backend,
#     which is not provisioned by deploy_sragent_to_client.sh.
# (Previously skipped global-flag variants like `--no-summaries` are now
# supported via the 4-field WORKLOAD format `name|global_args|subcommand|args`.)

# --- Paths (same as v1) -----------------------------------------------------
WORK_DIR="${WORK_DIR:-/tmp/sragent_work}"
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR:-/mnt/lustrefs/sragent_data}}"
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/$(date +%Y%m%d_%H%M%S)_all_readme}"

BCC_INCLUDE_NET=1
RUN_WORKLOADS=""

TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$HOME/SRAgent/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"
export NCBI_EMAIL="${NCBI_EMAIL:-mqsun@udel.edu}"
export NCBI_API_KEY="${NCBI_API_KEY:-}"

# --- Workload matrix --------------------------------------------------------
# Format: "name|global_args|subcommand|args" (4 pipe-separated fields).
# All entries below are taken VERBATIM from the README's "Examples" sections.
WORKLOADS=(
  # ===== entrez (2 README examples) =====
  "entrez_convert||entrez|\"Convert GSE121737 to SRX accessions\""
  "entrez_summarize||entrez|\"Summarize SRX4967527\""

  # ===== sragent (3 README examples) =====
  "sragent_summarize_srx||sragent|\"Summarize SRX4967527\""
  "sragent_publications||sragent|\"Obtain any available publications for GSE196830\""
  "sragent_tech_lookup||sragent|\"Which 10X Genomics technology was used for ERX11887200?\""

  # ===== papers (4 README examples; PDFs land in \$DATA on Lustre) =====
  "papers_srx||papers|SRX4967527 --output-dir \$DATA"
  "papers_srp||papers|SRP167700 --output-dir \$DATA"
  "papers_prjna||papers|PRJNA498286 --output-dir \$DATA"
  "papers_csv||papers|\$SCRIPT_DIR/../tests/fixtures/accessions.csv --output-dir \$DATA"

  # ===== srx-info (2 README examples; --use-database variant skipped) =====
  "srx_info_single||srx-info|25576380"
  "srx_info_multi||srx-info|36106630 32664033 27694586"

  # ===== metadata (1 README example, uses CSV fixture) =====
  "metadata_csv||metadata|\$SCRIPT_DIR/../tests/fixtures/metadata_input.csv"

  # ===== tissue-ontology (3 README examples) =====
  "tissue_brain||tissue-ontology|\"Categorize the following tissue: brain\""
  "tissue_multi||tissue-ontology|\"Tissues: lung, heart, liver\""
  "tissue_complex||tissue-ontology|\"Find the ontology term for the thin layer of epithelial cells lining the alveoli in lungs\""

  # ===== disease-ontology (3 README examples) =====
  "disease_heart||disease-ontology|\"Categorize the following disease: heart disorder\""
  "disease_mondo_lookup||disease-ontology|\"What is the MONDO ontology ID for congestive heart failure?\""
  "disease_multi||disease-ontology|\"Diseases: heart neoplasm, bursitis\""

  # ===== find-datasets (3 README variants — incl. --no-summaries via 2nd field) =====
  "find_datasets_basic||find-datasets|--max-datasets 2 \"Obtain recent single cell RNA-seq datasets in the SRA database\""
  "find_datasets_pig||find-datasets|--max-datasets 1 --organisms pig -- \"Obtain recent single cell RNA-seq datasets in the SRA database\""
  "find_datasets_pig_quiet|--no-summaries|find-datasets|--max-datasets 1 --organisms pig -- \"Obtain recent single cell RNA-seq datasets in the SRA database\""
)

# Total: 21 workloads (added --no-summaries variant)
# Estimated time: ~30-60 minutes (papers downloads + reasoning model latency)
