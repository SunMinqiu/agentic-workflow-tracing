# Config for the SciLink + BCC/eBPF tracing workflow on CloudLab CentOS 8.
#
# Path placement standard:
#   WORK_DIR (legacy default only)  → no longer used as the SciLink cwd by
#                       trace_script_bcc_scilink.sh; per-run cwd is
#                       $OUT/work so artifacts stay beside the trace
#   DATA_DIR (Lustre) → big downloads / generated artifacts (analysis PNGs,
#                       autonomous-mode generated python scripts, etc.)
#   BASE_OUT (results) → all per-run artefacts, including SciLink session-dir,
#                       ebpf log, parsed.json, DAG, metrics, and visualizations
#
# Re-runnable: every var below uses ${X:-default} so deploy_scilink_to_client.sh
# can override via .env without editing this file.

# --- Paths ------------------------------------------------------------------
WORK_DIR="${WORK_DIR:-/tmp/scilink_work}"
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR:-/mnt/lustrefs/scilink_data}}"
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/$(date +%Y%m%d_%H%M%S)}"

# Where SciLink itself lives on disk (its checkout is the cwd for resolving
# examples/eels_plasmons_demo/datacube.npy etc.).  deploy_scilink_to_client.sh
# clones into ~/SciLink.
SCILINK_REPO="${SCILINK_REPO:-$HOME/SciLink}"

# --- BCC / tracer -----------------------------------------------------------
# 1 = trace network syscalls (default), 0 = FS-only
BCC_INCLUDE_NET=1

# Optional comma-separated subset of workload names below; empty = all.
RUN_WORKLOADS="${RUN_WORKLOADS:-}"

# --- Two Pythons (forced by BCC binding constraint) -------------------------
# TRACER_PYTHON : system /usr/bin/python3 — has python3-bcc bindings.
# AGENT_PYTHON  : uv-built SciLink venv (Py 3.12) — runs SciLink + litellm.
#                 deploy_scilink_to_client.sh puts the real venv on Lustre
#                 and symlinks ~/SciLink/.venv to it, so .venv/bin/python
#                 resolves correctly without a separate Lustre path here.
TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$SCILINK_REPO/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

# --- LLM provider config (read by SciLink / litellm) ------------------------
export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"

# Default model.  Used by workloads that don't override it in their --model
# flag.  gpt-4o-mini is the cheapest sane choice for an EELS sanity trace;
# bump to gpt-4o or claude-opus-4-6 for more capable analyses.
SCILINK_MODEL="${SCILINK_MODEL:-gpt-4o-mini}"
SCILINK_EMBEDDING_MODEL="${SCILINK_EMBEDDING_MODEL:-text-embedding-3-small}"

# --- Workload matrix --------------------------------------------------------
# Format: "name|global_args|subcommand|args|prompt".
#   - global_args : SciLink has no global flags today; leave empty (just ||).
#   - subcommand  : always "analyze" for the current SciLink CLI.
#   - args        : forwarded to `scilink analyze`; split with eval set --.
#                   --mode autonomous is REQUIRED — it suppresses follow-up
#                   "would you like to..." prompts that would otherwise
#                   stall waiting for stdin we don't have.
#   - prompt      : free text fed via stdin as the agent's first message.
#                   Must NOT contain a literal '|' character.
#   - $SCILINK_REPO and $DATA expand at workload-launch time.
#
# Multiple demos can be added; copy the line and tweak --data/--metadata.

WORKLOADS=(
  # 1. eels_plasmons_demo — hyperspectral EELS plasmon mapping.
  # \$OUT and \$SCILINK_REPO are deferred — they expand at workload-launch
  # time inside trace_script_bcc_scilink.sh's `eval set -- "$SRARGS"`, not
  # when this config file is sourced.  $SCILINK_MODEL is fine to expand at
  # source time because it's defined above.
  "eels_plasmons_basic||analyze|--mode autonomous --model $SCILINK_MODEL --data \$SCILINK_REPO/examples/eels_plasmons_demo/datacube.npy --metadata \$SCILINK_REPO/examples/eels_plasmons_demo/datacube.json --session-dir \$OUT/scilink_session|Find and characterize the plasmon peaks in this EELS dataset."

  # 2. eels_identification_demo — 1D EELS spectrum identification.
  "eels_identification_basic||analyze|--mode autonomous --model $SCILINK_MODEL --data \$SCILINK_REPO/examples/eels_identification_demo/spectrum.npy --metadata \$SCILINK_REPO/examples/eels_identification_demo/spectrum.json --session-dir \$OUT/scilink_session|Identify the likely material or chemical species represented by this EELS spectrum. Report the strongest evidence and uncertainty."

  # 3. polycrystalline_grains_demo — 2D microscopy image analysis.
  "polycrystalline_grains_basic||analyze|--mode autonomous --model $SCILINK_MODEL --data \$SCILINK_REPO/examples/polycrystalline_grains_demo/image.npy --metadata \$SCILINK_REPO/examples/polycrystalline_grains_demo/image.json --session-dir \$OUT/scilink_session|Segment the polycrystalline grain structure, estimate grain-size statistics, and summarize the main microstructural features."

  # 4. planning_agent_demo — planning orchestrator (`plan`, not `analyze`).
  # Reads a data-dir (ICP-MS measurements) plus a knowledge-dir, so it is the
  # only SciLink workload with directory-traversal + embedding-index I/O; the
  # three analyze demos each read a single .npy. The prompt field is the
  # research objective, and the launcher supplies the session-dir answer via
  # stdin. CLI flags below were derived from the README, not from a real run —
  # verify with `scilink plan --help` on the client before the first traced pass.
  "planning_critical_materials||plan|--autonomy autonomous --model $SCILINK_MODEL --embedding-model $SCILINK_EMBEDDING_MODEL --data-dir \$SCILINK_REPO/examples/planning_agent_demo/experimental_data --knowledge-dir \$SCILINK_REPO/examples/planning_agent_demo/knowledge_folder|Recommend an experimental campaign for recovering critical materials from produced water using the provided ICP-MS measurements and DOE critical-material context."
)

# Notes:
# - To run a subset, set RUN_WORKLOADS="eels_plasmons_basic".
# - First full SciLink example pass:
#   RUN_WORKLOADS="eels_plasmons_basic,eels_identification_basic,polycrystalline_grains_basic"
# - $OUT is set to an absolute per-workload trace directory by
#   trace_script_bcc_scilink.sh BEFORE the eval,
#   so the --session-dir value above resolves to e.g.
#   /mnt/lustrefs/Minqiu/pi-ebpf-tracing-handoff/results/20260513_103000/eels_plasmons_basic/scilink_session.
# - SciLink CLI flags are best-effort from the README + cli/analyze.py
#   inspection at HEAD 429d48d.  If they drift, adjust above.
