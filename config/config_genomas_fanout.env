# Config for the GEO-only fanout study (Phase-1 input-shape scaling).
#
# This is NOT the Phase-4 max-workers matrix (that lives in
# config_genomas.env).  Here we hold model / workers / mode FIXED and scale
# only the INPUT SHAPE along two axes, to test how agent I/O grows with the
# work it is handed:
#
#   Axis 1 (cohort) : one high-cohort GEO trait, C = 1,2,4,8 cohorts.
#                     Probes: files ~ 3C, input-read bytes ~ C, shared
#                     small-file re-read ~ C, create/unlink churn.
#   Axis 2 (trait)  : T = 1,2,4,8 single-cohort GEO traits.
#                     Probes: dirs ~ 3T, cross-directory metadata spread,
#                     MDS create/lookup.
#
# The C=1 and T=1 points are the SAME run (1 trait x 1 cohort), so we run it
# ONCE as the shared baseline and reuse it as the origin of both axes.
#
# Everything is GEO-only, single-model, live, --quick-test (preprocess only),
# single worker (serial -> deterministic; this study is about input shape,
# not orchestration parallelism).
#
# Re-runnable: every var uses ${X:-default}; .env.genomas overrides win.

# --- Paths ------------------------------------------------------------------
# IMPORTANT: outputs go on LUSTRE, not the 16GB CloudLab root disk.  GenoMAS
# preprocess output alone is ~0.2-1.4GB/cell and WILL fill root.  Also make
# ~/GenoMAS/output a symlink to Lustre once per deploy:
#     mkdir -p /mnt/lustrefs/genomas_output
#     ln -sfn /mnt/lustrefs/genomas_output ~/GenoMAS/output
WORK_DIR="${WORK_DIR:-/tmp/genomas_work_fanout}"
# REAL data root (read-only source for the symlink views).
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR_GENOMAS:-/mnt/lustrefs/genomas_data}}"
# Where per-cell symlink views are built (cheap; symlinks only).
VIEW_ROOT="${VIEW_ROOT:-/tmp/genomas_fanout_views}"
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/fanout_$(date +%Y%m%d_%H%M%S)}"

GENOMAS_REPO="${GENOMAS_REPO:-$HOME/GenoMAS}"

# --- BCC / tracer -----------------------------------------------------------
BCC_INCLUDE_NET=1
COLLECT_LUSTRE_COUNTERS="${COLLECT_LUSTRE_COUNTERS:-0}"
LUSTRE_COUNTER_INTERVAL_SEC="${LUSTRE_COUNTER_INTERVAL_SEC:-1}"
INTER_RUN_SLEEP_SEC="${INTER_RUN_SLEEP_SEC:-30}"

# Optional comma-separated subset of cell names to run; empty = all.
RUN_CELLS="${RUN_CELLS:-}"

# --- Two Pythons (BCC binding constraint; same as config_genomas.env) -------
TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$GENOMAS_REPO/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

# --- LLM provider config ----------------------------------------------------
export OPENAI_API_KEY_1="${OPENAI_API_KEY_1:-${OPENAI_API_KEY:-}}"
export OPENAI_ORGANIZATION_1="${OPENAI_ORGANIZATION_1:-${OPENAI_ORGANIZATION:-}}"

# CHEAPEST OpenAI model (gpt-5 family, same API path GenoMAS already handles
# for gpt-5-mini).  ~$0.05 / 1M input, ~$0.40 / 1M output -> cheapest tier.
# Alternatives if nano misbehaves on this workload: gpt-4.1-nano, gpt-4o-mini.
# NOTE: pinned UNCONDITIONALLY (plain '=' not ':-') so it overrides the
# GENOMAS_MODEL=gpt-5-mini that deploy_genomas_to_client.sh bakes into
# .env.genomas (which the harness sources first).  Edit here to change.
GENOMAS_MODEL="${GENOMAS_MODEL:-gpt-5-mini-2025-08-07}"

# Live by default (this is the live study).  Replay vars kept for parity.
GENOMAS_LLM_REPLAY="${GENOMAS_LLM_REPLAY:-0}"
GENOMAS_LLM_REPLAY_STRICT="${GENOMAS_LLM_REPLAY_STRICT:-0}"
GENOMAS_LLM_CACHE_PATH="${GENOMAS_LLM_CACHE_PATH:-}"
export GENOMAS_LLM_REPLAY GENOMAS_LLM_REPLAY_STRICT GENOMAS_LLM_CACHE_PATH

# --- Fanout knobs (the only things you normally edit) -----------------------
# Axis 1: the ONE trait with many cohorts.  Must have >= max(COHORT_AXIS_C)
# cohort dirs under DATA_DIR/GEO/<trait>/.  (Inventory shows Type_1_Diabetes
# has 10 -> good for C up to 8.)
HIGH_COHORT_TRAIT="${HIGH_COHORT_TRAIT:-Type_1_Diabetes}"
COHORT_AXIS_C="${COHORT_AXIS_C:-1 2 4 8}"

# Axis 2: a pool of DISTINCT traits, each contributing exactly 1 cohort.
# You need at least max(TRAIT_AXIS_T) of them present under DATA_DIR/GEO/.
# The first entry doubles as the C=1=T=1 shared baseline, so making it equal
# to HIGH_COHORT_TRAIT keeps the origin identical for both axes.
# 8 single-cohort traits staged on Lustre (Type_1_Diabetes first = the
# C=1/T=1 shared baseline origin).  Enough for TRAIT_AXIS_T up to 8.
SINGLE_COHORT_TRAITS="${SINGLE_COHORT_TRAITS:-Type_1_Diabetes Type_2_Diabetes Vitamin_D_Levels Von_Hippel_Lindau Von_Willebrand_Disease Werner_Syndrome X-Linked_Lymphoproliferative_Syndrome lower_grade_glioma_and_glioblastoma}"
TRAIT_AXIS_T="${TRAIT_AXIS_T:-1 2 4 8}"
