# Config for the GenoMAS + BCC/eBPF tracing workflow on CloudLab CentOS 8.
#
# Path placement standard (same as SciLink/SRAgent harness):
#   GENOMAS_REPO         → GenoMAS checkout (resolves ./metadata/task_info.json
#                          and ./tools/preprocess.py)
#   DATA_DIR (Lustre)    → GEO + TCGA input data (lives across runs, not per-cell)
#   BASE_OUT (Lustre)    → per-cell trace artefacts (ebpf log, parsed.json, viz,
#                          logger output, post-processed summaries, etc.)
#
# Re-runnable: every var below uses ${X:-default} so deploy_genomas_to_client.sh
# can override via .env.genomas without editing this file.

# --- Paths ------------------------------------------------------------------
WORK_DIR="${WORK_DIR:-/tmp/genomas_work}"
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR_GENOMAS:-/mnt/lustrefs/genomas_data}}"
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/phase4_$(date +%Y%m%d_%H%M%S)}"

# Where GenoMAS itself lives on disk.  deploy_genomas_to_client.sh clones
# into ~/GenoMAS and writes the venv path into .env.genomas.
GENOMAS_REPO="${GENOMAS_REPO:-$HOME/GenoMAS}"

# --- BCC / tracer -----------------------------------------------------------
# 1 = trace network syscalls (default).  Strongly recommended for GenoMAS:
# every LLM call is an outbound HTTPS request → without --include-net we
# lose visibility into API-rate-limit waits, which is one of the suspected
# bottlenecks in Phase 4 at high max-workers.
BCC_INCLUDE_NET=1

# Optional Lustre mechanism-evidence sampler (§3.7).  Enable on CloudLab
# Lustre clients with: COLLECT_LUSTRE_COUNTERS=1.
COLLECT_LUSTRE_COUNTERS="${COLLECT_LUSTRE_COUNTERS:-0}"
LUSTRE_COUNTER_INTERVAL_SEC="${LUSTRE_COUNTER_INTERVAL_SEC:-1}"

# Optional comma-separated subset of workload names below; empty = run all.
# Useful for re-running just one matrix cell after a hardware glitch.
RUN_WORKLOADS="${RUN_WORKLOADS:-}"

# Sleep between cells, in seconds.  Lets OpenAI's per-minute rate-limit
# bucket drain so cell N doesn't inherit cell N-1's throttling.  Set to 0
# if you want back-to-back runs (and accept the rate-limit cross-talk).
INTER_RUN_SLEEP_SEC="${INTER_RUN_SLEEP_SEC:-30}"

# --- Two Pythons (forced by BCC binding constraint) -------------------------
# TRACER_PYTHON : system /usr/bin/python3 — has python3-bcc bindings (Py 3.6
#                 on CentOS Stream 8).  Only runs bcc_tracer.py.
# AGENT_PYTHON  : uv-built GenoMAS venv (Py 3.10) on Lustre, symlinked from
#                 ~/GenoMAS/.venv by deploy_genomas_to_client.sh.
TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$GENOMAS_REPO/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

# --- LLM provider config (read by GenoMAS) ----------------------------------
# These pass through into the GenoMAS python process; main.py's
# python-dotenv pulls from ~/GenoMAS/.env, so these are belt-and-suspenders
# for `sudo -E` (which strips most env if .env.genomas isn't sourced).
export OPENAI_API_KEY_1="${OPENAI_API_KEY_1:-${OPENAI_API_KEY:-}}"
export OPENAI_ORGANIZATION_1="${OPENAI_ORGANIZATION_1:-${OPENAI_ORGANIZATION:-}}"
export ANTHROPIC_API_KEY_1="${ANTHROPIC_API_KEY_1:-${ANTHROPIC_API_KEY:-}}"

# Default model — gpt-5-mini matches Phase 2 smoke baseline.  Keep this
# fixed across the whole Phase 4 matrix; vary only --max-workers per cell.
GENOMAS_MODEL="${GENOMAS_MODEL:-gpt-5-mini-2025-08-07}"

# LLM replay/cache mode. Live runs append llm_cache.jsonl by default. To replay
# without API calls, set GENOMAS_LLM_REPLAY=1 and point GENOMAS_LLM_CACHE_PATH at
# a previous run's llm_cache.jsonl.
GENOMAS_LLM_REPLAY="${GENOMAS_LLM_REPLAY:-0}"
GENOMAS_LLM_REPLAY_STRICT="${GENOMAS_LLM_REPLAY_STRICT:-0}"
GENOMAS_LLM_CACHE_PATH="${GENOMAS_LLM_CACHE_PATH:-}"
export GENOMAS_LLM_REPLAY GENOMAS_LLM_REPLAY_STRICT GENOMAS_LLM_CACHE_PATH

# Smoke-trait subset.  Empty → auto-detect from data_root subdirs (matches
# the launcher's default behaviour).  Set this explicitly to pin the matrix
# to the same traits across all 12 cells (recommended for fair comparison).
GENOMAS_SMOKE_TRAITS="${GENOMAS_SMOKE_TRAITS:-}"

# --- Workload matrix: sweep the REAL workload axes (trait × cohort) ---------
# Format: "name|max_workers|rep|extra_genomas_args"
#   - name      : cell id; becomes the subdir under BASE_OUT
#   - max_workers: --max-workers to main.py.  Per the design rule this is
#                  min(cohorts_per_trait, 4) — workers bind to cohort count,
#                  capped at 4.  Pre-computed per cell below.
#   - rep        : repetition index (kept for format compat; 1 here)
#   - extra_genomas_args: forwarded to the launcher.  We use it to set the
#                  actual workload: --smoke-traits <t1,t2,...> picks which
#                  traits, --max-cohorts N caps GEO cohorts PER TRAIT.
#
# NOTE: this sweeps trait count and cohort count (what actually drives I/O),
# NOT max-workers/rep.  max-workers is DERIVED (min(cohorts,4)); it is not a
# free axis.  Requires: (a) a full metadata/task_info.json on the client
# (git-restored, 132 traits w/ conditions — the launcher keeps 1 condition per
# trait so questions aren't empty), and (b) the deploy-patched environment.py
# that honours GENOMAS_MAX_COHORTS.
WORKLOADS=(
  # ---- Group A: cohort sweep on ONE trait (Type_1_Diabetes) ----
  #   cohorts = 1,2,4,8  →  workers = 1,2,4,4  (min(N,4))
  "A_c1_w1|1|1|--smoke-traits Type_1_Diabetes --max-cohorts 1"
  "A_c2_w2|2|1|--smoke-traits Type_1_Diabetes --max-cohorts 2"
  "A_c4_w4|4|1|--smoke-traits Type_1_Diabetes --max-cohorts 4"
  "A_c8_w4|4|1|--smoke-traits Type_1_Diabetes --max-cohorts 8"

  # ---- Group B: trait-count sweep (2 cohorts/trait fixed → workers=2) ----
  #   traits = 1,2,4 ; each trait capped at 2 GEO cohorts
  "B_t1_w2|2|1|--smoke-traits Type_1_Diabetes --max-cohorts 2"
  "B_t2_w2|2|1|--smoke-traits Type_1_Diabetes,Type_2_Diabetes --max-cohorts 2"
  "B_t4_w2|2|1|--smoke-traits Type_1_Diabetes,Type_2_Diabetes,Vitamin_D_Levels,Von_Hippel_Lindau --max-cohorts 2"
)

# Tips:
# - Sanity first: RUN_WORKLOADS="A_c1_w1" (1 trait, 1 cohort, 1 worker).
# - Cohort axis:  RUN_WORKLOADS="A_c1_w1,A_c2_w2,A_c4_w4,A_c8_w4".
# - Trait axis:   RUN_WORKLOADS="B_t1_w2,B_t2_w2,B_t4_w2".
# - Empty RUN_WORKLOADS runs all 7 cells.
# - Leave GENOMAS_SMOKE_TRAITS unset here — traits are chosen PER CELL via the
#   --smoke-traits in extra_genomas_args (a global value would double up).
