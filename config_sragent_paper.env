# Config v3: workloads aligned with the characterization paper.
#
# *** PLACEHOLDER — fill the WORKLOADS array below when you have the paper's
# *** workload list pinned down.
#
# Use this when you want to run only the workloads called out by the paper
# methodology (typically a curated subset chosen for representativeness or
# scaling, NOT exhaustive coverage like v2).
#
# Run me with:
#   CONFIG_FILE=~/pi-ebpf-tracing-handoff/config_sragent_paper.env \
#     sudo -E bash trace_script_bcc_sragent.sh

# --- Paths ------------------------------------------------------------------
WORK_DIR="${WORK_DIR:-/tmp/sragent_work}"
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR:-/mnt/lustrefs/sragent_data}}"
BASE_OUT="${BASE_OUT:-./traces/$(date +%Y%m%d_%H%M%S)_paper}"

BCC_INCLUDE_NET=1
RUN_WORKLOADS=""

TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$HOME/SRAgent/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"
export NCBI_EMAIL="${NCBI_EMAIL:-mqsun@udel.edu}"
export NCBI_API_KEY="${NCBI_API_KEY:-}"

# --- Workload matrix (paper-defined) ---------------------------------------
# TODO: fill this in once the paper's workload list is pinned.
# Format: "name|global_args|subcommand|args" (4 pipe-separated fields).
#   - global_args: SRAgent flags BEFORE subcommand (e.g. --no-summaries).
#                  Empty = `name||subcommand|args`.
#   - args: forwarded to `SRAgent <subcommand>`.
# Use \$DATA for Lustre output paths and \$SCRIPT_DIR for fixture paths.
# See config_sragent.env (v1) or _all_readme.env (v2) for concrete examples.
WORKLOADS=(
  # Example placeholder (delete once real workloads are added):
  # "paper_w1_some_workload||entrez|\"<paper-prompt-1>\""
  # "paper_w2_some_workload||sragent|\"<paper-prompt-2>\""
  # "paper_w3_with_globals|--no-summaries|find-datasets|--max-datasets 5 \"<paper-prompt-3>\""
)

# Sanity guard: if the array is empty, trace_script will refuse to run.
# Once you start filling this in, remove this comment block.
