# Config for the classic 1000genome direct-driver trace on CloudLab.

# --- Paths ------------------------------------------------------------------
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/classic_1000genome_$(date +%Y%m%d_%H%M%S)}"

# The checkout contains ~500 MiB compressed input and expands by many GiB.
# Keep it on Lustre; never default this workflow to the 16 GiB home/root disk.
WORKFLOW_REPO="${WORKFLOW_REPO:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/1000genome-workflow}"
DATASET_DIR="${DATASET_DIR:-$WORKFLOW_REPO/data/20130502}"
POPULATION_DIR="${POPULATION_DIR:-$WORKFLOW_REPO/data/populations}"

# Tasks consume decompressed VCFs. The upstream prepare_input.sh creates the
# main files in DATASET_DIR and annotation files under DATASET_DIR/sifting.
MAIN_VCF_NAME_TEMPLATE="${MAIN_VCF_NAME_TEMPLATE:-}"
ANNOTATION_VCF_NAME_TEMPLATE="${ANNOTATION_VCF_NAME_TEMPLATE:-}"
[ -n "$MAIN_VCF_NAME_TEMPLATE" ] || MAIN_VCF_NAME_TEMPLATE='ALL.chr{chromosome}.250000.vcf'
[ -n "$ANNOTATION_VCF_NAME_TEMPLATE" ] || ANNOTATION_VCF_NAME_TEMPLATE='ALL.chr{chromosome}.phase3_shapeit2_mvncall_integrated_v5.20130502.sites.annotation.vcf'
MAIN_VCF_SOURCE_TEMPLATE="${MAIN_VCF_SOURCE_TEMPLATE:-$DATASET_DIR/$MAIN_VCF_NAME_TEMPLATE}"
ANNOTATION_VCF_SOURCE_TEMPLATE="${ANNOTATION_VCF_SOURCE_TEMPLATE:-$DATASET_DIR/sifting/$ANNOTATION_VCF_NAME_TEMPLATE}"
COLUMNS_FILE="${COLUMNS_FILE:-$DATASET_DIR/columns.txt}"

# --- Tracing and Python runtimes --------------------------------------------
BCC_INCLUDE_NET="${BCC_INCLUDE_NET:-0}"
COLLECT_LUSTRE_COUNTERS="${COLLECT_LUSTRE_COUNTERS:-0}"
LUSTRE_COUNTER_INTERVAL_SEC="${LUSTRE_COUNTER_INTERVAL_SEC:-1}"
TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$WORKFLOW_REPO/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"
WORKFLOW_CMD="${WORKFLOW_CMD:-$AGENT_PYTHON -m agent_io_tracing.adapters.classic.run_1000genome}"

# --- Fixed baseline controls ------------------------------------------------
INDIVIDUAL_JOBS="${INDIVIDUAL_JOBS:-2}"
MAX_WORKERS="${MAX_WORKERS:-4}"
ROWS_PER_CHROMOSOME="${ROWS_PER_CHROMOSOME:-250000}"
POPULATIONS="${POPULATIONS:-ALL}"
RUN_WORKLOADS="${RUN_WORKLOADS:-}"
# 1 = explicitly mark this as an internet/API-free run. The trace path never
# downloads data; all scripts, wheels, and decompressed VCFs must be pre-staged.
CLASSIC_OFFLINE="${CLASSIC_OFFLINE:-1}"

# Format: name|number_of_chromosomes|repetition|extra_driver_args
WORKLOADS=(
  "classic_chr1_r1|1|1|"
  "classic_chr1_r2|1|2|"
  "classic_chr1_r3|1|3|"
  "classic_chr2_r1|2|1|"
  "classic_chr2_r2|2|2|"
  "classic_chr2_r3|2|3|"
  "classic_chr4_r1|4|1|"
  "classic_chr4_r2|4|2|"
  "classic_chr4_r3|4|3|"
)
