# Config for the ChemGraph XANES MCP + BCC/eBPF tracing workflow on CloudLab.
#
# Placement:
#   CHEMGRAPH_REPO      -> ChemGraph checkout in remote home
#   DATA_DIR (Lustre)   -> reusable CIF inputs and FDMNES working outputs
#   BASE_OUT (results)  -> per-run traces, logs, parsed.json, visualizations

WORK_DIR="${WORK_DIR:-/tmp/chemgraph_work}"
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR_CHEMGRAPH:-/mnt/lustrefs/chemgraph_data}}"
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/chemgraph_$(date +%Y%m%d_%H%M%S)}"

CHEMGRAPH_REPO="${CHEMGRAPH_REPO:-$HOME/ChemGraph}"
FDMNES_EXE="${FDMNES_EXE:-/mnt/lustrefs/fdmnes/fdmnes}"

# 1 = trace network syscalls too; useful for LLM calls.
BCC_INCLUDE_NET=1

# Optional comma-separated subset of workload names below; empty = all.
RUN_WORKLOADS="${RUN_WORKLOADS:-}"

TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$CHEMGRAPH_REPO/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export MP_API_KEY="${MP_API_KEY:-}"
export FDMNES_EXE

# Use a ChemGraph-supported OpenAI model name.  The upstream stdio example says
# "gpt4o", but e9e83bc's model loader expects the hyphenated OpenAI names.
CHEMGRAPH_MODEL="${CHEMGRAPH_MODEL:-gpt-4o-mini}"

# Format: "name|model|prompt".
# $DATA and $OUT expand at workload-launch time in trace_script_bcc_chemgraph.sh.
WORKLOADS=(
  "xanes_single|$CHEMGRAPH_MODEL|Run a XANES calculation on the file \$DATA/Fe2O3.cif at the Fe K-edge with Z_absorber=26 and a cluster radius of 3.0 Angstrom. Write all calculation outputs under \$OUT/xanes_output."
  "xanes_ensemble_dir|$CHEMGRAPH_MODEL|Run XANES ensemble calculations for all CIF files in \$DATA/ensemble_structs at the Fe K-edge with Z_absorber=26 and a cluster radius of 3.0 Angstrom. Use run_xanes_ensemble with output_dir \$OUT/xanes_ensemble_output, max_parallel 3, and fdmnes_exe \$FDMNES_EXE. After the ensemble finishes, call plot_xanes on the returned runs_dir."
)
