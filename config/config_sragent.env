# Config for the SRAgent + BCC/eBPF tracing workflow on CloudLab CentOS 8.
#
# Path placement standard:
#   WORK_DIR (local)  → cwd, ChromaDB, appdirs cache, small SRAgent state
#   DATA_DIR (Lustre) → big downloads (PDFs, fastq), filtered datasets,
#                       fastq-dump tempfiles ($TMPDIR)
#   BASE_OUT (results) → trace artefacts (ebpf log, parsed.json, viz)

# --- Paths ------------------------------------------------------------------
WORK_DIR="${WORK_DIR:-/tmp/sragent_work}"
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR:-/mnt/lustrefs/sragent_data}}"
RESULTS_OWNER="${RESULTS_OWNER:-${SUDO_USER:-${SSH_USER:-${USER:-Minqiu}}}}"
RESULTS_ROOT="${RESULTS_ROOT:-${MOUNT_PATH:-/mnt/lustrefs}/$RESULTS_OWNER/pi-ebpf-tracing-handoff/results}"
BASE_OUT="${BASE_OUT:-$RESULTS_ROOT/$(date +%Y%m%d_%H%M%S)}"

# --- BCC / tracer -----------------------------------------------------------
# 1 = trace network syscalls (default), 0 = FS-only (original measurement set)
BCC_INCLUDE_NET=1

# Optional comma-separated subset of workload names below; empty = all.
RUN_WORKLOADS=""

# --- Two Pythons (forced by BCC binding constraint) -------------------------
# TRACER_PYTHON  : system /usr/bin/python3 — has python3-bcc bindings (Py 3.6
#                  on CentOS Stream 8).  Runs only bcc_tracer.py.
# AGENT_PYTHON   : uv-built venv (Py 3.11+) — has SRAgent + LangChain.
#                  Runs analyze_codebase_sragent.py + post-processing.
TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$HOME/SRAgent/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

# --- LLM provider config (read by SRAgent / langchain) ---------------------
export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"

# --- NCBI Entrez (lifts rate limit 3→10 req/s; recommended) ----------------
export NCBI_EMAIL="${NCBI_EMAIL:-mqsun@udel.edu}"
export NCBI_API_KEY="${NCBI_API_KEY:-}"

# --- Workload matrix --------------------------------------------------------
# Format: "name|global_args|subcommand|args".
# - global_args: SRAgent flags BEFORE the subcommand (e.g. --no-summaries).
#   Empty = `name||subcommand|args` (just two pipes).
# - args: forwarded to `SRAgent <subcommand>`; split by `eval set --`.
# - `\$DATA` and `\$SCRIPT_DIR` expand at workload-launch time.
# Examples below are taken VERBATIM from the SRAgent README
# (https://github.com/ArcInstitute/SRAgent#readme).
WORKLOADS=(
  # 1. entrez — accession conversion (README: "Convert GSE121737 to SRX accessions")
  "entrez_basic||entrez|\"Convert GSE121737 to SRX accessions\""

  # 2. sragent — high-level dataset summary (README: "Summarize SRX4967527")
  "sragent_basic||sragent|\"Summarize SRX4967527\""

  # 3. metadata — accession CSV → consolidated metadata.
  "metadata_basic||metadata|\$SCRIPT_DIR/../tests/fixtures/metadata_input.csv"

  # 4. find-datasets — keyword discovery + per-dataset SRX-info enrichment.
  "find_datasets_basic||find-datasets|--max-datasets 2 \"Obtain recent single cell RNA-seq datasets in the SRA database\""

  # 5. papers — accession → manuscript download (positional accession per README).
  "papers_basic||papers|SRX4967527 --output-dir \$DATA"

  # 6. srx-info — Entrez ID → metadata (NUMERIC Entrez ID, not SRX!).
  "srx_info_basic||srx-info|25576380"

  # 7. tissue-ontology — text → Uberon (queries local ChromaDB).
  "tissue_ontology_basic||tissue-ontology|\"Categorize the following tissue: brain\""

  # 8. disease-ontology — text → MONDO (local ChromaDB).
  "disease_ontology_basic||disease-ontology|\"Categorize the following disease: heart disorder\""
)

# Notes:
# - To expand each class, duplicate a line and tweak args + name.
# - To run a subset, set RUN_WORKLOADS="entrez_basic,papers_basic".
# - SRAgent flag names are best-effort from the README; verify with
#   `SRAgent <sub> --help` and adjust above (especially --output-dir).
