# Config for the GenoMAS + BCC/eBPF tracing workflow on CloudLab CentOS 8.
#
# Path placement standard (same as SciLink/SRAgent harness):
#   GENOMAS_REPO         → GenoMAS checkout (resolves ./metadata/task_info.json
#                          and ./tools/preprocess.py)
#   DATA_DIR (Lustre)    → GEO + TCGA input data (lives across runs, not per-cell)
#   BASE_OUT (local)     → per-cell trace artefacts (ebpf log, parsed.json, viz,
#                          GenoMAS output/preprocess/*, etc.)
#
# Re-runnable: every var below uses ${X:-default} so deploy_genomas_to_client.sh
# can override via .env.genomas without editing this file.

# --- Paths ------------------------------------------------------------------
WORK_DIR="${WORK_DIR:-/tmp/genomas_work}"
DATA_DIR="${DATA_DIR:-${REMOTE_DATA_DIR_GENOMAS:-/mnt/lustrefs/genomas_data}}"
BASE_OUT="${BASE_OUT:-./traces/phase4_$(date +%Y%m%d_%H%M%S)}"

# Where GenoMAS itself lives on disk.  deploy_genomas_to_client.sh clones
# into ~/GenoMAS and writes the venv path into .env.genomas.
GENOMAS_REPO="${GENOMAS_REPO:-$HOME/GenoMAS}"

# --- BCC / tracer -----------------------------------------------------------
# 1 = trace network syscalls (default).  Strongly recommended for GenoMAS:
# every LLM call is an outbound HTTPS request → without --include-net we
# lose visibility into API-rate-limit waits, which is one of the suspected
# bottlenecks in Phase 4 at high max-workers.
BCC_INCLUDE_NET=1

# Optional comma-separated subset of workload names below; empty = run all.
# Useful for re-running just one matrix cell after a hardware glitch.
RUN_WORKLOADS=""

# Sleep between cells, in seconds.  Lets OpenAI's per-minute rate-limit
# bucket drain so cell N doesn't inherit cell N-1's throttling.  Set to 0
# if you want back-to-back runs (and accept the rate-limit cross-talk).
INTER_RUN_SLEEP_SEC="${INTER_RUN_SLEEP_SEC:-30}"

# --- Two Pythons (forced by BCC binding constraint) -------------------------
# TRACER_PYTHON : system /usr/bin/python3 — has python3-bcc bindings (Py 3.6
#                 on CentOS Stream 8).  Only runs bcc_tracer.py.
# AGENT_PYTHON  : uv-built GenoMAS venv (Py 3.10) on Lustre, symlinked from
#                 ~/GenoMAS/.venv by deploy_genomas_to_client.sh.
TRACER_PYTHON="${TRACER_PYTHON:-/usr/bin/python3}"
AGENT_PYTHON="${AGENT_PYTHON:-$GENOMAS_REPO/.venv/bin/python}"
POST_PYTHON="${POST_PYTHON:-$AGENT_PYTHON}"

# --- LLM provider config (read by GenoMAS) ----------------------------------
# These pass through into the GenoMAS python process; main.py's
# python-dotenv pulls from ~/GenoMAS/.env, so these are belt-and-suspenders
# for `sudo -E` (which strips most env if .env.genomas isn't sourced).
export OPENAI_API_KEY_1="${OPENAI_API_KEY_1:-${OPENAI_API_KEY:-}}"
export OPENAI_ORGANIZATION_1="${OPENAI_ORGANIZATION_1:-${OPENAI_ORGANIZATION:-}}"
export ANTHROPIC_API_KEY_1="${ANTHROPIC_API_KEY_1:-${ANTHROPIC_API_KEY:-}}"

# Default model — gpt-5-mini matches Phase 2 smoke baseline.  Keep this
# fixed across the whole Phase 4 matrix; vary only --max-workers per cell.
GENOMAS_MODEL="${GENOMAS_MODEL:-gpt-5-mini-2025-08-07}"

# Smoke-trait subset.  Empty → auto-detect from data_root subdirs (matches
# the launcher's default behaviour).  Set this explicitly to pin the matrix
# to the same traits across all 12 cells (recommended for fair comparison).
GENOMAS_SMOKE_TRAITS="${GENOMAS_SMOKE_TRAITS:-}"

# --- Workload matrix (Phase 4 cells) ---------------------------------------
# Format: "name|max_workers|rep|extra_genomas_args"
#   - name      : free-form cell id; becomes the subdir under BASE_OUT
#   - max_workers: integer; --max-workers passed to main.py
#   - rep        : integer; used to disambiguate identical settings across reps
#   - extra_genomas_args: forwarded verbatim to analyze_codebase_genomas.py
#                         AFTER the standard flags.  Default empty.
#
# The full Phase 4 matrix below = 4 max-workers × 3 reps = 12 cells.
# mw=1 cells provide the serial baseline; mw={2,4,8} measure achieved
# parallelism.  All cells use --parallel-mode cohorts and --quick-test;
# vary that here only if you know what you're changing.
WORKLOADS=(
  "mw1_rep1|1|1|"
  "mw1_rep2|1|2|"
  "mw1_rep3|1|3|"
  "mw2_rep1|2|1|"
  "mw2_rep2|2|2|"
  "mw2_rep3|2|3|"
  "mw4_rep1|4|1|"
  "mw4_rep2|4|2|"
  "mw4_rep3|4|3|"
  "mw8_rep1|8|1|"
  "mw8_rep2|8|2|"
  "mw8_rep3|8|3|"
)

# Tips:
# - For a fast Phase-4 sanity run: set RUN_WORKLOADS="mw1_rep1,mw4_rep1" to
#   confirm both ends of the matrix work before launching all 12 cells.
# - For a no-BCC sanity run: set BCC_INCLUDE_NET=0 and edit
#   trace_script_bcc_genomas.sh to skip the tracer attach (or just run
#   analyze_codebase_genomas.py directly without sudo).
